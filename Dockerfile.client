FROM golang:1.26@sha256:68cb6d68bed024785b69195b89af7ac7a444f27791435f98647edff595aa0479 AS builder

# Build arguments for version information
ARG VERSION=dev
ARG BUILD_DATE
ARG GIT_COMMIT

WORKDIR /app
COPY . .
RUN CGO_ENABLED=0 GOOS=linux go build -ldflags "-s -w \
    -X github.com/PhilipSchmid/flow-generator-app/internal/version.Version=${VERSION} \
    -X github.com/PhilipSchmid/flow-generator-app/internal/version.BuildDate=${BUILD_DATE} \
    -X github.com/PhilipSchmid/flow-generator-app/internal/version.GitCommit=${GIT_COMMIT}" \
    -o flow-generator ./cmd/client
FROM scratch
COPY --from=builder /app/flow-generator /
ENTRYPOINT ["/flow-generator"]